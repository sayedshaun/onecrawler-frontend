# Backend origin that /api requests are proxied to.
# Dev (docker compose -f docker-compose.dev.yml up): read by vite.config.ts for the Vite dev server proxy.
# Prod (docker compose up): read by the Caddyfile for the Caddy reverse proxy.
#
# Running `npm run dev` directly on the host: http://localhost:8000 works.
# Running via Docker Compose (backend is a separate compose project, e.g.
# onecrawler-backend, publishing 8000 to the host): use http://host.docker.internal:8000 —
# "localhost" inside this container refers to the container itself, not the host.
API_PROXY_TARGET=http://host.docker.internal:8000

# onecrawler-agents-backend origin that /agents-api requests are proxied to.
# Same dev/prod split as API_PROXY_TARGET above.
AGENTS_API_PROXY_TARGET=http://host.docker.internal:8001
